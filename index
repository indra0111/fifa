<html>
<head>
   <script>
       /***********************************SCRIPT EDIT START*****************************************/

       /*----------------------- Environment -----------*/
       const env = "Prod";

       /*------ Video Asset ---*/
       const assets = [
           "https://www.lenovo.com/content/dam/lenovo/cross-bu-campaigns/fy-26-27/intel-dws-fifa-campaign/intel/global-english/videos/dws-customer-reference-video-/full/Lenovo_FIFA_CustomerStory_Hero_16x9_CLEAN.mp4"
       ];

       const enableOverlay = true;

       /*------Publisher Info ------*/
       const pubClientId = 2658;
       const siteIdWeb = 3;
       const siteIdMweb = 39;

       /*----- Advertiser Info ----*/
       const lineItemId = 5858844;

       /*---------Bot Info----------*/
       const campaignIdentifier = "adgpt_lenovo_webv1";
       const wa_bot_alias = "na";

       /*------ FIFA Chatbot Page (same host as this ad tag) ------*/
       const chatbotPageUrl = "http://10.68.70.11:8080/fifa-adtalk-chatbot.html";

       /***********************************SCRIPT EDIT END*****************************************/
   </script>

   <style>
       body{
           font-family:Poppins,sans-serif;
           cursor:pointer;
           padding:0;
           margin:0;
           overflow:hidden;
           position:relative;
           width:300px;
           height:250px;
           background:#000;
       }

       /* AdTalk renderCreative injects its own player on body; hide it — we use custom FIFA layout */
       .vid-container,
       .video-ended{
           display:none !important;
       }

       .brand-bar{
           position:absolute;
           top:0;
           left:0;
           width:100%;
           background:#000;
           color:#fff;
           padding:8px 12px;
           z-index:20;
           display:flex;
           justify-content:space-between;
           align-items:center;
           box-sizing:border-box;
           border-bottom:1px solid #1f1f1f;
       }

       .brand-logo{
           display:inline-flex;
           align-items:center;
           justify-content:center;
           background:#000;
           padding:1px 3px;
           line-height:0;
           flex-shrink:0;
       }

       .brand-bar img{
           height:12px;
           width:auto;
           display:block;
           object-fit:contain;
       }

       .brand-bar span{
           color:#d1d5db;
           font-size:10px;
           font-weight:700;
           letter-spacing:0.05em;
           text-transform:uppercase;
       }

       .vid{
           position:absolute;
           top:34px;
           left:0;
           right:0;
           bottom:40px;
           width:100%;
           height:auto;
           background-color:#000;
           object-fit:cover;
           object-position:center;
           opacity:0.8;
           cursor:pointer;
           z-index:1;
       }

       .bottom-bar{
           position:absolute;
           left:0;
           right:0;
           bottom:0;
           height:40px;
           background:#000;
           display:flex;
           align-items:center;
           justify-content:center;
           z-index:101;
       }

       .cta-btn{
           background:#e2231a;
           color:#fff;
           padding:5px 20px;
           border-radius:9999px;
           font-size:11px;
           font-weight:700;
           z-index:101;
           border:none;
           cursor:pointer;
           box-shadow:0 4px 6px rgba(0,0,0,0.3);
       }

       .cta-btn:hover{
           background:#b91c1c;
       }

       .mute-btn{
           position:absolute;
           top:42px;
           right:10px;
           width:35px;
           height:35px;
           border-radius:50%;
           background:rgba(0,0,0,0.6);
           color:#fff;
           border:none;
           z-index:102;
           font-size:16px;
           cursor:pointer;
       }
   </style>
</head>

<body>

   <div class="brand-bar">
       <div class="brand-logo">
           <img src="https://media.lenovonews.fiestic.com/2023/05/08023828/Lenovo-Logo-scaled.jpg" alt="Lenovo" />
       </div>
       <span>Official Tech Partner</span>
   </div>

   <video id="adVideo" class="vid" autoplay muted loop playsinline>
       <source src="https://www.lenovo.com/content/dam/lenovo/cross-bu-campaigns/fy-26-27/intel-dws-fifa-campaign/intel/global-english/videos/dws-customer-reference-video-/full/Lenovo_FIFA_CustomerStory_Hero_16x9_CLEAN.mp4">
   </video>

   <button class="mute-btn" id="muteToggle">🔇</button>

   <div class="bottom-bar">
       <button class="cta-btn" id="ctaButton">Explore the Tech</button>
   </div>

   <script src="https://static.clmbtech.com/ad/commons/js/adtalk/adtalk.js"></script>

   <script>
       const video = document.getElementById("adVideo");
       const muteToggle = document.getElementById("muteToggle");

       muteToggle.addEventListener("click", function(event){
           event.stopPropagation();

           if(video.muted){
               video.muted = false;
               muteToggle.innerHTML = "🔊";
           } else {
               video.muted = true;
               muteToggle.innerHTML = "🔇";
           }
       });

       const pageURL = new URL(parent.location.href),
       botEnv = "stg" === pageURL.searchParams.get("gpt_type") ? "STAGING" : "PRODUCTION",
       LpUrl = "https://chat.timesadtalk.ai/bot/v1.html",
       adServerType = window.frameElement && window.frameElement.id.includes("^ifr_") ? "CAN" : "GAM",

       adTalkConfig = {
           lineItemId: lineItemId,
           pubClientId: pubClientId,
           siteIdWeb: siteIdWeb,
           siteIdMweb: siteIdMweb,
           env: env,
           adServerType: "GAM",
           behaviourSource: 21
       };

       new adTalk.Init(adTalkConfig);

       const render = new adTalk.Render;

       render.renderCreative(assets);

       "CAN" !== adServerType && new adTalk.Visibility(document.body);

       let clickLog = !1;

       const adTalkData = window.adTalkData,
       dsmi = Boolean(+adTalkData.dsmi);

       if (
           enableOverlay &&
           window.frameElement &&
           !document.getElementById("adgpt-container") &&
           !parent.sdkJSloaded
       ) {
           try {
               const e = document.createElement("div");

               e.id = "adgpt-container";

               parent.document.body.appendChild(e);

               let a = document.createElement("script");

               a.src = "https://chat.timesadtalk.ai/js/v1/sdk.js";

               a.onload = () => {
                   parent.sdkJSloaded = !0
               };

               a.async = !1;

               parent.document.body.appendChild(a)
           } catch (err) {}
       }

       let lastTime = 0;

       function ensureChatbotOverlayStyles() {
           let style = parent.document.getElementById("fifa-chatbot-overlay-styles");
           if (!style) {
               style = parent.document.createElement("style");
               style.id = "fifa-chatbot-overlay-styles";
               parent.document.head.appendChild(style);
           }
           style.textContent = `
               #custom-chatbot-overlay {
                   position: fixed;
                   inset: 0;
                   z-index: 999999999;
                   display: flex;
                   align-items: flex-end;
                   justify-content: center;
                   padding: 0;
                   padding-top: 10vh;
                   background: rgba(0, 0, 0, 0);
                   opacity: 0;
               }
               #custom-chatbot-overlay.fifa-open {
                   animation: fifaOverlayFadeIn 0.3s ease-out forwards;
               }
               #custom-chatbot-overlay.fifa-closing {
                   animation: fifaOverlayFadeOut 0.25s ease-in forwards;
               }
               @keyframes fifaOverlayFadeIn {
                   from { background: rgba(0, 0, 0, 0); opacity: 0; }
                   to { background: rgba(0, 0, 0, 0.5); opacity: 1; }
               }
               @keyframes fifaOverlayFadeOut {
                   from { background: rgba(0, 0, 0, 0.5); opacity: 1; }
                   to { background: rgba(0, 0, 0, 0); opacity: 0; }
               }
               #custom-chatbot-overlay .fifa-chatbot-panel {
                   position: relative;
                   width: 100%;
                   height: 90dvh;
                   max-height: 800px;
                   background: #ffffff;
                   border-radius: 16px 16px 0 0;
                   overflow: hidden;
                   box-shadow: 0 0 40px rgba(0, 0, 0, 0.4);
                   border-top: 1px solid #d1d5db;
                   opacity: 0;
                   transform: translateY(40px) scale(0.9);
               }
               #custom-chatbot-overlay.fifa-open .fifa-chatbot-panel {
                   animation: fifaPanelSlideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
               }
               #custom-chatbot-overlay.fifa-closing .fifa-chatbot-panel {
                   animation: fifaPanelSlideOut 0.28s ease-in forwards;
               }
               @keyframes fifaPanelSlideIn {
                   from { opacity: 0; transform: translateY(40px) scale(0.9); }
                   to { opacity: 1; transform: translateY(0) scale(1); }
               }
               @keyframes fifaPanelSlideOut {
                   from { opacity: 1; transform: translateY(0) scale(1); }
                   to { opacity: 0; transform: translateY(40px) scale(0.9); }
               }
               #custom-chatbot-overlay .fifa-chatbot-close {
                   position: absolute;
                   top: 8px;
                   right: 8px;
                   z-index: 3;
                   width: 28px;
                   height: 28px;
                   border: none;
                   border-radius: 50%;
                   background: #000;
                   color: #fff;
                   font-size: 20px;
                   line-height: 28px;
                   cursor: pointer;
               }
               @media (min-width: 640px) {
                   #custom-chatbot-overlay {
                       align-items: center;
                       justify-content: center;
                       padding: 5vh;
                       padding-top: 5vh;
                   }
                   #custom-chatbot-overlay .fifa-chatbot-panel {
                       width: 700px;
                       height: 90vh;
                       max-height: 800px;
                       border-radius: 16px;
                       border: 1px solid #9ca3af;
                       box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
                   }
               }
           `;
       }

       function ensureCloseListener() {
           if (parent.document.getElementById("fifa-chatbot-close-listener")) return;

           const script = parent.document.createElement("script");
           script.id = "fifa-chatbot-close-listener";
           script.textContent = `
               if (!window.__fifaChatbotCloseBound) {
                   window.__fifaChatbotCloseBound = true;
                   window.__hideFifaChatbotOverlay = function() {
                       var overlay = document.getElementById("custom-chatbot-overlay");
                       if (!overlay || overlay.classList.contains("fifa-closing")) return;
                       overlay.classList.add("fifa-closing");
                       overlay.classList.remove("fifa-open");
                       setTimeout(function() {
                           overlay.style.display = "none";
                           overlay.classList.remove("fifa-closing");
                       }, 280);
                   };
                   window.addEventListener("message", function(e) {
                       if (e.data && e.data.type === "CLOSE_FIFA_CHATBOT") {
                           window.__hideFifaChatbotOverlay();
                       }
                   });
               }
           `;
           parent.document.head.appendChild(script);
       }

       function hideChatbotOverlay(overlay) {
           if (!overlay || overlay.classList.contains("fifa-closing")) return;
           if (parent.__hideFifaChatbotOverlay) {
               parent.__hideFifaChatbotOverlay();
               return;
           }
           overlay.classList.add("fifa-closing");
           overlay.classList.remove("fifa-open");
           setTimeout(function() {
               overlay.style.display = "none";
               overlay.classList.remove("fifa-closing");
           }, 280);
       }

       function showChatbotOverlay(overlay) {
           overlay.style.display = "flex";
           overlay.classList.remove("fifa-closing");
           requestAnimationFrame(function() {
               requestAnimationFrame(function() {
                   overlay.classList.add("fifa-open");
               });
           });
       }

       function openChatBot(event) {
           event.stopPropagation();

           ensureChatbotOverlayStyles();
           ensureCloseListener();

           const chatbotUrl = new URL(chatbotPageUrl, window.location.href).href;
           const existingOverlay = parent.document.getElementById("custom-chatbot-overlay");

           if (existingOverlay) {
               showChatbotOverlay(existingOverlay);
               return;
           }

           const overlay = parent.document.createElement("div");
           overlay.id = "custom-chatbot-overlay";

           overlay.addEventListener("click", function(e) {
               if (e.target === overlay) hideChatbotOverlay(overlay);
           });

           const panel = parent.document.createElement("div");
           panel.className = "fifa-chatbot-panel";

           const closeBtn = parent.document.createElement("button");
           closeBtn.className = "fifa-chatbot-close";
           closeBtn.innerHTML = "×";
           closeBtn.setAttribute("aria-label", "Close");
           closeBtn.addEventListener("click", function(e) {
               e.stopPropagation();
               hideChatbotOverlay(overlay);
           });

           const iframe = parent.document.createElement("iframe");
           iframe.src = chatbotUrl;
           iframe.title = "Lenovo FIFA Chatbot";
           iframe.style.cssText = "width:100%;height:100%;border:none;display:block;";

           panel.appendChild(closeBtn);
           panel.appendChild(iframe);
           overlay.appendChild(panel);
           parent.document.body.appendChild(overlay);
           showChatbotOverlay(overlay);
       }

       /* GAM-compatible click binding — same as working tag */
       const videoElement = document.getElementById("adVideo");
       const ctaElement = document.getElementById("ctaButton");

       videoElement.addEventListener("click", openChatBot);
       ctaElement.addEventListener("click", openChatBot);
   </script>

</body>
</html>


